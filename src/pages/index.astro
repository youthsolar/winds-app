---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "找風問幸福",
  "alternateName": "Uneedwind",
  "url": "https://app.winds.tw",
  "description": "找風問幸福提供通靈問事、元辰宮代觀、命理諮詢、開光法器與量能精油，由專業老師一對一服務。台灣最完整的靈性命理諮詢平台。",
  "inLanguage": "zh-TW",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://app.winds.tw/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout
  title="找風問幸福｜通靈問事・元辰宮・開光法器・命理諮詢"
  description="找風問幸福提供通靈水鏡法查因果、元辰宮代觀知運勢、開光符令與法器、量能精油等靈性命理服務，由風易揚、風賜靈、芊蘭老師一對一服務。"
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-4 py-16 text-center">
    <h1 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--winds-text-dark);">
      看清命運的方向<br />讓心有所依歸
    </h1>
    <p class="text-lg mb-8" style="color: var(--winds-text-sub);">
      通靈問事・元辰宮代觀・開光法器・量能精油<br />
      找風問幸福，台灣最完整的靈性命理諮詢平台
    </p>
    <div class="flex justify-center gap-4">
      <a
        href="/services"
        class="inline-block px-8 py-3 rounded-lg text-white font-bold"
        style="background: var(--winds-gold-dark);"
      >
        探索服務與法器
      </a>
      <a
        href="/blog"
        class="inline-block px-8 py-3 rounded-lg border font-bold"
        style="border-color: var(--winds-gold-dark); color: var(--winds-gold-dark);"
      >
        命理專欄
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-[var(--winds-bg-card)] rounded-xl p-6 border border-[var(--winds-border)] text-center">
        <div class="text-3xl mb-3">🔮</div>
        <h2 class="text-lg font-bold mb-2">通靈問事</h2>
        <p style="color: var(--winds-text-sub);">透過靈視水鏡直達無形界，查因果、看前世、解疑惑</p>
      </div>
      <div class="bg-[var(--winds-bg-card)] rounded-xl p-6 border border-[var(--winds-border)] text-center">
        <div class="text-3xl mb-3">🏛️</div>
        <h2 class="text-lg font-bold mb-2">元辰宮代觀</h2>
        <p style="color: var(--winds-text-sub);">老師代入靈界親見你的元辰宮，洞察運勢根源與修補方向</p>
      </div>
      <div class="bg-[var(--winds-bg-card)] rounded-xl p-6 border border-[var(--winds-border)] text-center">
        <div class="text-3xl mb-3">✨</div>
        <h2 class="text-lg font-bold mb-2">開光法器與精油</h2>
        <p style="color: var(--winds-text-sub);">老師依個案親撰開光，符令、法鏡、量能精油，全台超商店到店</p>
      </div>
    </div>
  </section>

  <!-- Trust Section (GEO-friendly: clear factual statements) -->
  <section class="max-w-3xl mx-auto px-4 py-12 text-center">
    <h2 class="text-xl font-bold mb-6">為什麼選擇找風問幸福？</h2>
    <div class="grid md:grid-cols-2 gap-4 text-left text-sm" style="color: var(--winds-text-sub);">
      <div class="flex gap-2"><span>✅</span><span>風易揚、風賜靈、芊蘭三位老師，一對一親自服務</span></div>
      <div class="flex gap-2"><span>✅</span><span>39 種預約服務 + 22 種開光法器，涵蓋感情、事業、健康、財運</span></div>
      <div class="flex gap-2"><span>✅</span><span>服務地點台北市，亦支援遠端視訊諮詢</span></div>
      <div class="flex gap-2"><span>✅</span><span>法器全台超商店到店，7 天內到貨</span></div>
      <div class="flex gap-2"><span>✅</span><span>AI 輔助占卜分析，結合命理智慧與科技</span></div>
      <div class="flex gap-2"><span>✅</span><span>Google 帳號一鍵登入，安全便利</span></div>
    </div>
  </section>
</BaseLayout>
