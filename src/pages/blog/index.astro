---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Group by category
const categorized: Record<string, typeof allPosts> = {};
for (const p of allPosts) {
  const cat = p.data.category || '其他';
  if (!categorized[cat]) categorized[cat] = [];
  categorized[cat].push(p);
}

const categoryOrder = ['感情挽回','桃花運','斬桃花','元辰宮','財運','塔羅','星座','命理','其他','兩性關係','感情和合','開運招財','命理占卜'];
const sortedCats = Object.keys(categorized).sort((a, b) => {
  const ai = categoryOrder.indexOf(a);
  const bi = categoryOrder.indexOf(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

const pageTitle = "找風問幸福｜靈炁命理部落格・感情挽回・桃花運・補財庫・元辰宮";
const pageDesc = "找風問幸福部落格：感情挽回、桃花運、補財庫、元辰宮修補、塔羅占卜等 340+ 篇靈炁命理文章，由風易揚、風賜靈、芊蘭、伊紫蓮、竹韻、玄奇六位老師分享真實個案。";
---

<BaseLayout title={pageTitle} description={pageDesc} ogType="website">
  <main class="blog-list">
    <header class="list-header">
      <h1>✨ 靈炁命理專欄</h1>
      <p class="subtitle">由老師分享的真實個案與靈性智慧</p>
      <p class="count">共 {allPosts.length} 篇文章</p>
      <div class="divider"></div>
    </header>

    <nav class="cat-nav">
      {sortedCats.map(cat => (
        <a href={`#cat-${encodeURIComponent(cat)}`} class="cat-pill">
          {cat}
          <span class="cat-count">{categorized[cat].length}</span>
        </a>
      ))}
    </nav>

    {sortedCats.map(cat => (
      <section class="cat-section" id={`cat-${encodeURIComponent(cat)}`}>
        <h2 class="cat-title">{cat}</h2>
        <ul class="post-list">
          {categorized[cat].slice(0, 20).map(post => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`}>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <time>{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </a>
            </li>
          ))}
        </ul>
        {categorized[cat].length > 20 && (
          <p class="more-hint">還有 {categorized[cat].length - 20} 篇 {cat} 的文章…</p>
        )}
      </section>
    ))}

    <div class="cta-bottom">
      <p class="cta-text">🔮 想知道你現在的量能狀態？</p>
      <a href="/" class="cta-btn">立即免費占卜 3 分鐘</a>
    </div>
  </main>
</BaseLayout>

<style>
  .blog-list {
    max-width: 780px;
    margin: 0 auto;
    padding: 32px 20px 60px;
  }

  .list-header {
    text-align: center;
    margin-bottom: 32px;
  }
  .list-header h1 {
    font-family: 'LXGW WenKai TC', serif;
    font-size: 28px;
    color: var(--winds-text-dark);
    margin: 0 0 10px;
  }
  .list-header .subtitle {
    font-size: 14px;
    color: var(--winds-text-sub);
    margin: 0 0 6px;
  }
  .list-header .count {
    font-size: 12px;
    color: var(--winds-text-muted);
    margin: 0;
  }
  .list-header .divider {
    height: 2px;
    background: linear-gradient(to right, transparent, var(--winds-gold-light), transparent);
    margin: 20px auto 0;
    max-width: 200px;
  }

  .cat-nav {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 36px;
    padding: 16px;
    background: var(--winds-bg-card);
    border-radius: 12px;
    border: 1px solid var(--winds-border);
  }
  .cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--winds-gold-light);
    color: var(--winds-gold-dark);
    font-size: 13px;
    text-decoration: none;
    transition: transform 0.15s;
  }
  .cat-pill:hover {
    transform: translateY(-1px);
    text-decoration: none;
  }
  .cat-pill .cat-count {
    background: var(--winds-text-dark);
    color: #fff;
    font-size: 10px;
    padding: 1px 7px;
    border-radius: 10px;
    font-weight: 600;
  }

  .cat-section {
    margin-bottom: 40px;
    scroll-margin-top: 80px;
  }
  .cat-title {
    font-family: 'LXGW WenKai TC', serif;
    font-size: 20px;
    color: var(--winds-gold-dark);
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--winds-border);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-item {
    margin-bottom: 16px;
  }
  .post-item a {
    display: block;
    padding: 18px 20px;
    background: var(--winds-bg-card);
    border: 1px solid var(--winds-border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .post-item a:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(139, 105, 20, 0.08);
    text-decoration: none;
  }
  .post-title {
    font-family: 'LXGW WenKai TC', serif;
    font-size: 16px;
    color: var(--winds-text-dark);
    margin: 0 0 8px;
    line-height: 1.5;
  }
  .post-item a:hover .post-title {
    color: var(--winds-gold-dark);
  }
  .post-desc {
    font-size: 13px;
    color: var(--winds-text-sub);
    line-height: 1.7;
    margin: 0 0 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 11px;
    color: var(--winds-text-muted);
  }
  .post-meta .tag {
    color: var(--winds-gold-dark);
  }

  .more-hint {
    text-align: center;
    font-size: 12px;
    color: var(--winds-text-muted);
    margin: 12px 0 0;
    font-style: italic;
  }

  .cta-bottom {
    margin-top: 48px;
    padding: 32px 20px;
    background: linear-gradient(135deg, var(--winds-gold-light), #fdf8f0);
    border-radius: 12px;
    text-align: center;
  }
  .cta-bottom .cta-text {
    font-family: 'LXGW WenKai TC', serif;
    font-size: 16px;
    color: var(--winds-text-dark);
    margin: 0 0 16px;
  }
  .cta-bottom .cta-btn {
    display: inline-block;
    padding: 12px 32px;
    background: var(--winds-text-dark);
    color: #fff;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s;
  }
  .cta-bottom .cta-btn:hover {
    transform: scale(1.03);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .blog-list { padding: 20px 16px 40px; }
    .list-header h1 { font-size: 22px; }
    .cat-title { font-size: 17px; }
    .post-title { font-size: 15px; }
  }
</style>
