---
// 紫微斗數 — 人生藍圖
// 入口：/ziwei
// 流程：使用者填表 → 呼叫 api.winds.tw/ziwei-chart → 渲染 ZiweiChart 元件

import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = '紫微斗數命盤 — 人生藍圖｜找風問幸福';
const pageDesc = '免費生成紫微斗數命盤，支援真太陽時校正（海外華人準確）。 12 宮主星副星完整、AI 命理師深度解讀，作為你的人生藍圖參考。';
---

<BaseLayout title={pageTitle} description={pageDesc} ogType="website">
  <main class="ziwei-main">
    <header class="page-header">
      <h1>紫微斗數命盤</h1>
      <p class="subtitle">傳統紫微 12 宮排盤 ＋ AI 命理師解讀 ＋ 真太陽時校正（海外華人準確）</p>
    </header>

    <!-- 登入閘（未登入時顯示）-->
    <section class="auth-gate" id="auth-gate" hidden>
      <div class="auth-card">
        <h2>請先登入</h2>
        <p class="auth-desc">紫微命盤是個人深度產品，需要登入後才能生成。<br/>每位使用者終身只能算一次，請慎重填寫。</p>
        <div id="g_id_signin_ziwei"></div>
        <p class="auth-note">登入即代表同意 <a href="/privacy">隱私權政策</a> 與 <a href="/terms">服務條款</a></p>
      </div>
    </section>

    <!-- 偵測中 -->
    <section class="loading-section" id="loading-section" hidden>
      <p>讀取中…</p>
    </section>

    <section class="form-section" id="form-section" hidden>
      <p class="form-warning">⚠️ 紫微命盤每位使用者終身只能算一次。請仔細確認生日、時辰、性別、出生地，送出後無法修改。</p>
      <form id="ziwei-form" class="ziwei-form">
        <div class="row">
          <label for="solarDate">西元生日（陽曆）</label>
          <input type="date" id="solarDate" name="solarDate" required min="1900-01-01" max="2100-12-31" />
        </div>

        <div class="row two-col">
          <div>
            <label for="hour">出生時辰</label>
            <select id="hour" name="hour">
              <option value="">— 不確定（用午時 12:00）—</option>
              <option value="0">早子時（23-00 / 00-01）</option>
              <option value="1">丑時（01-03）</option>
              <option value="3">寅時（03-05）</option>
              <option value="5">卯時（05-07）</option>
              <option value="7">辰時（07-09）</option>
              <option value="9">巳時（09-11）</option>
              <option value="11">午時（11-13）</option>
              <option value="13">未時（13-15）</option>
              <option value="15">申時（15-17）</option>
              <option value="17">酉時（17-19）</option>
              <option value="19">戌時（19-21）</option>
              <option value="21">亥時（21-23）</option>
            </select>
          </div>
          <div>
            <label for="gender">性別</label>
            <select id="gender" name="gender" required>
              <option value="女">女</option>
              <option value="男">男</option>
            </select>
          </div>
        </div>

        <div class="row">
          <label for="longitude">出生地經度（選填，海外華人建議填）</label>
          <select id="longitude" name="longitude">
            <option value="">— 不校正（適合台灣出生）—</option>
            <option value="121.5">台北 121.5°E</option>
            <option value="116.4">北京 116.4°E（-14 min）</option>
            <option value="114.1">香港 114.1°E（-24 min）</option>
            <option value="139.7">東京 139.7°E（+19 min）</option>
            <option value="103.8">新加坡 103.8°E（+15 min, MYT/SGT 為 120°E zone）</option>
            <option value="-122.4">舊金山 -122.4°E（-10 min）</option>
            <option value="-123.1">溫哥華 -123.1°E（-12 min）</option>
            <option value="-118.2">洛杉磯 -118.2°E（+7 min）</option>
            <option value="-73.9">紐約 -73.9°E（+4 min）</option>
            <option value="-0.1">倫敦 -0.1°E（-0.4 min）</option>
          </select>
        </div>

        <button type="submit" class="submit-btn">
          <span class="btn-default">生成命盤</span>
          <span class="btn-loading" hidden>計算中…</span>
        </button>

        <p class="form-note">
          命盤本身免費 + 7 段試讀（每段 150 字）。付 NT$199 解鎖完整解讀（每段 600-800 字）+ 流年運勢 + 大限詳解 + 永久分享 URL。
        </p>
      </form>
    </section>

    <section id="result-section" hidden>
      <div class="result-meta">
        <span id="tst-badge" class="tst-badge" hidden></span>
        <span id="paid-badge" class="paid-badge" hidden>已解鎖完整解讀 ✓</span>
      </div>
      <div id="chart-toggle" class="chart-toggle" hidden>
        <button class="toggle-btn is-active" data-mode="natal">本命盤</button>
        <button class="toggle-btn" data-mode="yearly">流年盤 (今年)</button>
      </div>
      <div id="chart-mount"></div>
      <div id="unlock-cta" class="unlock-cta" hidden>
        <h3>解鎖完整解讀</h3>
        <p>目前每段為前 150 字試讀。付 NT$199 一次性買斷後，立即解鎖：</p>
        <ul>
          <li>全 7 段完整解讀（每段 600-800 字）</li>
          <li>本命盤 + 流年盤 + 大限詳解</li>
          <li>永久分享 URL，可分享給朋友</li>
        </ul>
        <button id="unlock-btn" class="unlock-btn">立即解鎖 NT$199 →</button>
      </div>
      <div id="share-block" class="share-block" hidden>
        <h4>分享我的命盤</h4>
        <input id="share-url" type="text" readonly />
        <button id="share-copy">複製連結</button>
      </div>
      <div id="interpretation-mount"></div>
    </section>

    <section id="error-section" class="error-section" hidden>
      <p id="error-msg"></p>
    </section>
  </main>
</BaseLayout>

<script>
  const WORKER_API = 'https://api.winds.tw';
  const FOCUS_PALACES = ['summary', '命宮', '父母', '夫妻', '財帛', '官祿', '福德'];
  const PALACE_LABEL: Record<string, string> = {
    summary: '整體格局',
    '命宮': '命宮（自我）',
    '父母': '父母宮（原生家庭）',
    '夫妻': '夫妻宮（伴侶）',
    '財帛': '財帛宮（金錢）',
    '官祿': '官祿宮（事業）',
    '福德': '福德宮（精神）',
  };

  type Star = { name: string; type?: string; brightness: string; mutagen: string };
  type AdjStar = { name: string };
  type Palace = {
    index: number; name: string;
    heavenlyStem: string; earthlyBranch: string;
    isBodyPalace: boolean; isOriginalPalace?: boolean;
    majorStars: Star[]; minorStars: Star[]; adjectiveStars: AdjStar[];
    decadal: { range: [number, number]; heavenlyStem: string; earthlyBranch: string };
  };
  type Chart = { meta: any; palaces: Palace[] };
  type HoroscopeItem = {
    index: number; name: string;
    heavenlyStem: string; earthlyBranch: string;
    palaceNames: string[]; mutagen: string[];
  };
  type Horoscope = {
    date: string; lunarDate: string;
    decadal: HoroscopeItem;
    age: HoroscopeItem & { nominalAge: number };
    yearly: HoroscopeItem & { yearlyDecStar?: any };
    monthly: HoroscopeItem;
    daily: HoroscopeItem;
  };

  const form = document.getElementById('ziwei-form') as HTMLFormElement;
  const authGate = document.getElementById('auth-gate') as HTMLElement;
  const loadingSection = document.getElementById('loading-section') as HTMLElement;
  const formSection = document.getElementById('form-section') as HTMLElement;
  const resultSection = document.getElementById('result-section') as HTMLElement;
  const errorSection = document.getElementById('error-section') as HTMLElement;
  const errorMsg = document.getElementById('error-msg') as HTMLElement;
  const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;
  const btnDefault = submitBtn?.querySelector('.btn-default') as HTMLElement;
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLElement;

  // === 認證 token ===
  function getGoogleToken(): string {
    let t = '';
    try { t = localStorage.getItem('winds_google_token') || ''; } catch (e) {}
    if (!t) return '';
    try {
      const p = JSON.parse(atob(t.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
      if (p.exp && p.exp * 1000 < Date.now()) {
        try { localStorage.removeItem('winds_google_token'); } catch (e) {}
        return '';
      }
    } catch (e) { return ''; }
    return t;
  }

  function authHeaders(): Record<string, string> {
    const t = getGoogleToken();
    return t ? { 'X-Google-Id-Token': t } : {};
  }

  function setLoading(on: boolean) {
    if (!submitBtn) return;
    submitBtn.disabled = on;
    btnDefault.hidden = on;
    btnLoading.hidden = !on;
  }

  function hideAllSections() {
    authGate.hidden = true;
    loadingSection.hidden = true;
    formSection.hidden = true;
    resultSection.hidden = true;
    errorSection.hidden = true;
  }

  function showError(msg: string) {
    errorMsg.textContent = msg;
    hideAllSections();
    errorSection.hidden = false;
  }

  function resetUI() {
    hideAllSections();
    formSection.hidden = false;
    setLoading(false);
  }

  // 化星顏色（繁中 key 對齊 worker setLanguage('zh-TW') 輸出）
  const MUTAGEN_COLOR: Record<string, string> = {
    '祿': 'mutagen-lu', '權': 'mutagen-quan', '科': 'mutagen-ke', '忌': 'mutagen-ji',
  };

  // 12 地支 → 4×4 grid
  const BRANCH_POS: Record<string, [number, number]> = {
    '巳': [0, 0], '午': [0, 1], '未': [0, 2], '申': [0, 3],
    '辰': [1, 0],                              '酉': [1, 3],
    '卯': [2, 0],                              '戌': [2, 3],
    '寅': [3, 0], '丑': [3, 1], '子': [3, 2], '亥': [3, 3],
  };

  // 計算當事人虛歲（中州派紫微大限以虛歲計算）
  // 虛歲 = 西元當前年 - 西元出生年 + 1
  function calcVirtualAge(birthSolarDate: string): number {
    const [by] = birthSolarDate.split('-').map(Number);
    return new Date().getFullYear() - by + 1;
  }

  function renderChart(chart: Chart, mount: HTMLElement, horoscope?: Horoscope | null, mode: 'natal' | 'yearly' = 'natal') {
    const grid: Array<Palace | null> = Array(16).fill(null);
    for (const p of chart.palaces) {
      const pos = BRANCH_POS[p.earthlyBranch];
      if (pos) grid[pos[0] * 4 + pos[1]] = p;
    }

    const currentAge = calcVirtualAge(chart.meta.solarDate);
    // 找當前大限所在的 palace index
    let currentDecadalIndex = -1;
    for (const p of chart.palaces) {
      if (p.decadal && currentAge >= p.decadal.range[0] && currentAge <= p.decadal.range[1]) {
        currentDecadalIndex = p.index;
        break;
      }
    }

    // 流年模式準備：palaceNames[index] = 該本命 index 在流年的宮名
    // 流年化星 mutagen[0,1,2,3] 對應 [祿, 權, 科, 忌]
    const yearly = mode === 'yearly' && horoscope ? horoscope.yearly : null;
    const yearlyMutagenMap: Record<string, string> = {};
    if (yearly) {
      const labels = ['祿', '權', '科', '忌'];
      yearly.mutagen.forEach((star, i) => { if (star) yearlyMutagenMap[star] = labels[i]; });
    }

    const cells = grid.map((cell, i) => {
      const row = Math.floor(i / 4);
      const col = i % 4;

      // 中宮 2x2 — Plan B 合併版（6-7 行，padding 留白足夠）
      if (row === 1 && col === 1) {
        const m = chart.meta;
        const timeStr = m.timeRange ? `${m.time} (${m.timeRange})` : m.time;
        return `<div class="center-meta" style="grid-row: 2 / 4; grid-column: 2 / 4;">
          <div class="meta-row meta-row-inline"><span class="meta-pill">${m.gender}</span><span class="meta-value">${m.solarDate}</span><span class="meta-sep">·</span><span class="meta-value">${timeStr}</span></div>
          <div class="meta-row meta-line-center">${m.lunarDate}</div>
          <div class="meta-row meta-line-center">${m.chineseDate}</div>
          <div class="meta-divider"></div>
          <div class="meta-row meta-row-inline"><span class="meta-label">命主</span><span class="meta-value meta-emphasize">${m.soul}</span><span class="meta-sep">·</span><span class="meta-label">身主</span><span class="meta-value meta-emphasize">${m.body}</span></div>
          <div class="meta-row meta-row-inline"><span class="meta-label">五行局</span><span class="meta-value meta-emphasize">${m.fiveElementsClass}</span></div>
          <div class="meta-row meta-line-center"><span class="meta-value">${m.sign}</span><span class="meta-sep">·</span><span class="meta-value">屬${m.zodiac}</span></div>
        </div>`;
      }
      if ((row === 1 && col === 2) || (row === 2 && col === 1) || (row === 2 && col === 2)) return '';
      if (!cell) return '<div class="palace-cell empty"></div>';

      const renderStar = (s: Star, kind: 'major' | 'minor') => {
        const yearlyTag = yearlyMutagenMap[s.name];
        return `<div class="star ${kind}">
          <span class="star-name">${s.name}</span>
          ${s.brightness ? `<span class="star-brightness">${s.brightness}</span>` : ''}
          ${s.mutagen ? `<span class="star-mutagen ${MUTAGEN_COLOR[s.mutagen] || ''}">化${s.mutagen}</span>` : ''}
          ${yearlyTag ? `<span class="star-mutagen yearly-mutagen ${MUTAGEN_COLOR[yearlyTag] || ''}">流${yearlyTag}</span>` : ''}
        </div>`;
      };
      const majors = cell.majorStars.map((s) => renderStar(s, 'major')).join('');
      const minors = cell.minorStars.map((s) => renderStar(s, 'minor')).join('');
      // 雜星收摺：cell 內顯示「+N」徽章，click 展開 popover 浮在 cell 上方
      const adj = cell.adjectiveStars.length
        ? `<button class="adj-toggle" data-action="toggle-adj" type="button" title="${cell.adjectiveStars.map(s => s.name).join('、')}">
            <span class="adj-count">${cell.adjectiveStars.length}</span><span class="adj-tag">雜</span>
          </button>
          <div class="adj-popover" hidden>${cell.adjectiveStars.map(s => `<span class="adj-star">${s.name}</span>`).join('')}</div>`
        : '';
      const empty = cell.majorStars.length === 0 && cell.minorStars.length === 0 ? '<span class="empty-palace">空宮</span>' : '';

      const isCurrentDecadal = cell.index === currentDecadalIndex;
      const yearlyName = yearly ? yearly.palaceNames[cell.index] : null;
      const isYearlySoul = yearly ? cell.index === yearly.index : false;

      return `<div class="palace-cell ${cell.isBodyPalace ? 'is-body' : ''} ${cell.isOriginalPalace ? 'is-origin' : ''} ${isCurrentDecadal ? 'is-current-decadal' : ''} ${isYearlySoul ? 'is-yearly-soul' : ''}" data-palace-index="${cell.index}">
        ${isCurrentDecadal && mode === 'natal' ? '<div class="current-decadal-badge">目前大限</div>' : ''}
        ${isYearlySoul && mode === 'yearly' ? '<div class="yearly-soul-badge">流年命宮</div>' : ''}
        <div class="cell-header">
          <span class="palace-name">${cell.name}${cell.isBodyPalace ? '<em class="body-tag">身</em>' : ''}</span>
          <span class="cell-stem-branch">${cell.heavenlyStem}${cell.earthlyBranch}</span>
        </div>
        <div class="cell-stars">
          ${empty}${majors}${minors}${adj}
        </div>
        <div class="cell-footer">
          ${yearlyName
            ? `<span class="yearly-footer">流年・${yearlyName}</span>`
            : (cell.decadal ? `<span class="decadal">大限 ${cell.decadal.range[0]}-${cell.decadal.range[1]}</span>` : '')}
        </div>
      </div>`;
    }).join('');

    mount.innerHTML = `<div class="ziwei-chart"><div class="ziwei-grid">${cells}</div></div>`;

    // 三方四正 hover
    const cellsEl = mount.querySelectorAll<HTMLElement>('.palace-cell[data-palace-index]');
    cellsEl.forEach(cell => {
      cell.addEventListener('mouseenter', () => {
        const idx = Number(cell.dataset.palaceIndex);
        const trines = new Set([idx, (idx + 6) % 12, (idx + 4) % 12, (idx + 8) % 12]);
        cellsEl.forEach(c => {
          const i = Number(c.dataset.palaceIndex);
          c.classList.toggle('trine-highlight', trines.has(i) && i !== idx);
          c.classList.toggle('trine-focus', i === idx);
        });
      });
      cell.addEventListener('mouseleave', () => {
        cellsEl.forEach(c => c.classList.remove('trine-highlight', 'trine-focus'));
      });
    });

    // 雜星 popover toggle（手機/桌面通用）
    mount.addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      const toggleBtn = target.closest<HTMLElement>('[data-action="toggle-adj"]');
      // 先關掉所有已開的 popover
      const allPopovers = mount.querySelectorAll<HTMLElement>('.adj-popover:not([hidden])');
      if (toggleBtn) {
        const cell = toggleBtn.closest('.palace-cell');
        const popover = cell?.querySelector<HTMLElement>('.adj-popover');
        const isOpen = popover && !popover.hidden;
        // 關閉其他所有
        allPopovers.forEach(p => { if (p !== popover) p.hidden = true; });
        // toggle 自己
        if (popover) popover.hidden = isOpen ? true : false;
        ev.stopPropagation();
      } else {
        // click 在外面 → 關全部
        allPopovers.forEach(p => p.hidden = true);
      }
    });
  }

  function renderInterpretationSkeleton(mount: HTMLElement, mode: 'natal' | 'yearly', year?: number) {
    const title = mode === 'yearly' ? `AI 命理師解讀 — ${year} 年流年運勢` : 'AI 命理師解讀';
    const blocks = FOCUS_PALACES.map(p => `
      <article class="interp-block" data-palace="${p}" data-mode="${mode}">
        <h3>${PALACE_LABEL[p]}</h3>
        <div class="interp-text loading">解讀生成中…</div>
      </article>`).join('');
    mount.innerHTML = `<section class="interpretation-section">
      <h2>${title}</h2>
      <p class="ai-note">由 Sonnet 4.6 模型即時生成，每段獨立呼叫，平均總耗時 20-30 秒</p>
      ${blocks}
    </section>`;
  }

  // YearlyContext for backend
  function buildYearlyContextForApi(horoscope: Horoscope) {
    return {
      year: parseInt(horoscope.date.split('-')[0]),
      yearlyHeavenlyStem: horoscope.yearly.heavenlyStem,
      yearlyEarthlyBranch: horoscope.yearly.earthlyBranch,
      yearlyPalaceNames: horoscope.yearly.palaceNames,
      yearlyMutagen: horoscope.yearly.mutagen,
      decadalHeavenlyStem: horoscope.decadal.heavenlyStem,
      decadalEarthlyBranch: horoscope.decadal.earthlyBranch,
      decadalPalaceNames: horoscope.decadal.palaceNames,
      nominalAge: horoscope.age.nominalAge,
    };
  }

  async function fetchPalace(_chart: Chart, palace: string, mode: 'natal' | 'yearly' = 'natal', yearly?: ReturnType<typeof buildYearlyContextForApi>) {
    const r = await fetch(`${WORKER_API}/ziwei-interpret-palace`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', ...authHeaders() },
      body: JSON.stringify({ palace, mode, yearly }),
    });
    const data = await r.json() as { ok?: boolean; text?: string; paid?: boolean; error?: string };
    return data.ok ? (data.text || '') : null;
  }

  function renderPalaceText(palace: string, text: string | null, mount: HTMLElement) {
    const block = mount.querySelector(`[data-palace="${palace}"] .interp-text`);
    if (!block) return;
    block.classList.remove('loading');
    if (text) {
      block.textContent = text;
    } else {
      block.classList.add('error');
      const failed = '此段生成失敗，';
      block.innerHTML = `${failed}<button class="retry-palace" data-palace="${palace}">重試</button>`;
    }
  }

  // 主入口：根據 chartData 渲染結果區（共用 newly-created / already-existing 路徑）
  function showResult(chartData: any) {
    hideAllSections();
    resultSection.hidden = false;

    const tstBadge = document.getElementById('tst-badge') as HTMLElement;
    if (chartData.tst?.applied) {
      tstBadge.hidden = false;
      const sign = chartData.tst.correctionMinutes >= 0 ? '+' : '';
      tstBadge.textContent = `已套用真太陽時校正（${sign}${chartData.tst.correctionMinutes} 分鐘）`;
    } else {
      tstBadge.hidden = true;
    }

    // toggle 顯示（只在有 horoscope 時）
    const chartToggle = document.getElementById('chart-toggle') as HTMLElement;
    chartToggle.hidden = !chartData.horoscope;

    const horoscope = chartData.horoscope as Horoscope | null;
    const yearlyApiCtx = horoscope ? buildYearlyContextForApi(horoscope) : null;
    const currentYear = yearlyApiCtx?.year;

    // 流年盤的 toggle button label 帶當前年份
    if (currentYear) {
      const yBtn = chartToggle.querySelector<HTMLButtonElement>('.toggle-btn[data-mode="yearly"]');
      if (yBtn) yBtn.textContent = `流年盤 (${currentYear})`;
    }

    const chartMount = document.getElementById('chart-mount') as HTMLElement;
    const interpMount = document.getElementById('interpretation-mount') as HTMLElement;
    let currentMode: 'natal' | 'yearly' = 'natal';

    // client-side 解讀 cache：避免來回切換重複 fetch
    const interpCache: { natal: Record<string, string | null>; yearly: Record<string, string | null> } = {
      natal: {},
      yearly: {},
    };
    const interpStarted: { natal: boolean; yearly: boolean } = { natal: false, yearly: false };

    const renderChartCurrent = () => renderChart(chartData.chart as Chart, chartMount, horoscope, currentMode);

    // 載入指定 mode 的 7 段解讀（首次才打 API，已 cached 直接渲染）
    const loadInterpretations = (mode: 'natal' | 'yearly') => {
      renderInterpretationSkeleton(interpMount, mode, currentYear);
      const cache = interpCache[mode];
      // 已有的 cache 立刻渲染
      for (const palace of FOCUS_PALACES) {
        if (cache[palace] !== undefined) {
          renderPalaceText(palace, cache[palace], interpMount);
        }
      }
      // 沒打過就打
      if (!interpStarted[mode]) {
        interpStarted[mode] = true;
        FOCUS_PALACES.forEach(async (palace) => {
          const text = await fetchPalace(chartData.chart as Chart, palace, mode, mode === 'yearly' ? yearlyApiCtx ?? undefined : undefined);
          cache[palace] = text;
          // 只在當前 mode 還是這個時渲染（避免快速切換 race condition）
          if (currentMode === mode) renderPalaceText(palace, text, interpMount);
        });
      }
    };

    renderChartCurrent();
    loadInterpretations('natal');

    chartToggle.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach((btn) => {
      btn.onclick = () => {
        const mode = btn.dataset.mode as 'natal' | 'yearly';
        if (mode === currentMode) return;
        currentMode = mode;
        chartToggle.querySelectorAll('.toggle-btn').forEach((b) => b.classList.toggle('is-active', b === btn));
        renderChartCurrent();
        loadInterpretations(mode);
      };
    });

    // Retry handler (delegated)
    interpMount.addEventListener('click', async (ev) => {
      const target = ev.target as HTMLElement;
      if (target.classList.contains('retry-palace')) {
        const palace = target.dataset.palace;
        if (!palace) return;
        const block = interpMount.querySelector(`[data-palace="${palace}"] .interp-text`);
        if (!block) return;
        block.className = 'interp-text loading';
        block.textContent = '重試中…';
        const text = await fetchPalace(chartData.chart as Chart, palace, currentMode, currentMode === 'yearly' ? yearlyApiCtx ?? undefined : undefined);
        interpCache[currentMode][palace] = text;
        renderPalaceText(palace, text, interpMount);
      }
    });

    // 解鎖按鈕（未付費才顯示）
    const unlockCta = document.getElementById('unlock-cta') as HTMLElement;
    const unlockBtn = document.getElementById('unlock-btn') as HTMLButtonElement;
    const paidBadge = document.getElementById('paid-badge') as HTMLElement;
    if (chartData.paid) {
      unlockCta.hidden = true;
      paidBadge.hidden = false;
    } else {
      unlockCta.hidden = false;
      paidBadge.hidden = true;
    }
    unlockBtn.onclick = async () => {
      unlockBtn.disabled = true;
      unlockBtn.textContent = '建立訂單中…';
      try {
        const r = await fetch(`${WORKER_API}/ziwei-create-order`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...authHeaders() },
          body: JSON.stringify({}),
        });
        const d = await r.json() as any;
        if (d.success && d.pay_url) {
          window.location.href = d.pay_url;
        } else if (d.already_paid) {
          location.reload();
        } else {
          throw new Error(d.error || '訂單建立失敗');
        }
      } catch (err: any) {
        alert(err.message || '無法建立訂單，請稍後再試');
        unlockBtn.disabled = false;
        unlockBtn.textContent = '立即解鎖 NT$199 →';
      }
    };

    // 分享連結
    const shareBlock = document.getElementById('share-block') as HTMLElement;
    const shareUrlInput = document.getElementById('share-url') as HTMLInputElement;
    const shareCopyBtn = document.getElementById('share-copy') as HTMLButtonElement;
    if (chartData.share_token) {
      shareBlock.hidden = false;
      shareUrlInput.value = `https://app.winds.tw/ziwei/share/${chartData.share_token}`;
      shareCopyBtn.onclick = async () => {
        try {
          await navigator.clipboard.writeText(shareUrlInput.value);
          shareCopyBtn.textContent = '已複製 ✓';
          setTimeout(() => { shareCopyBtn.textContent = '複製連結'; }, 2000);
        } catch {
          shareUrlInput.select();
        }
      };
    } else {
      shareBlock.hidden = true;
    }
  }

  // === Form submit：新使用者算盤 ===
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    setLoading(true);
    errorSection.hidden = true;

    const fd = new FormData(form);
    const payload: Record<string, unknown> = {
      solarDate: fd.get('solarDate'),
      gender: fd.get('gender'),
      withHoroscope: true,
    };
    const hour = fd.get('hour');
    if (hour) payload.hour = Number(hour);
    const lon = fd.get('longitude');
    if (lon) payload.longitude = Number(lon);

    let chartData: any;
    try {
      const r = await fetch(`${WORKER_API}/ziwei-chart`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', ...authHeaders() },
        body: JSON.stringify(payload),
      });
      chartData = await r.json();
      // 已存在情況也走 showResult（worker 會回 already_exists + chart）
      if (!chartData.ok && !chartData.already_exists) {
        throw new Error(chartData.error || chartData.message || '命盤生成失敗');
      }
      if (chartData.already_exists) {
        // 此使用者已有命盤，補拿 horoscope（worker 已存的 my-chart）
        const my = await fetch(`${WORKER_API}/ziwei-my-chart`, { headers: authHeaders() }).then((x) => x.json());
        chartData = my;
      }
    } catch (err: any) {
      showError(err.message || '無法連線到伺服器');
      setLoading(false);
      return;
    }

    setLoading(false);
    showResult(chartData);
  });

  // === Google Sign-In button render（在 auth-gate 內） ===
  function renderGoogleSignIn() {
    const clientId = (document.querySelector('[data-client_id]') as HTMLElement | null)?.dataset.client_id;
    if (!clientId) return;
    // 等 GIS script 載入
    const tryRender = () => {
      const g = (window as any).google?.accounts?.id;
      if (!g) { setTimeout(tryRender, 200); return; }
      g.initialize({
        client_id: clientId,
        callback: (resp: { credential: string }) => {
          try { localStorage.setItem('winds_google_token', resp.credential); } catch {}
          location.reload();
        },
      });
      const target = document.getElementById('g_id_signin_ziwei');
      if (target) {
        g.renderButton(target, { theme: 'outline', size: 'large', text: 'signin_with', locale: 'zh_TW', width: 280 });
      }
    };
    tryRender();
  }

  // === 進站偵測：有 token + 有命盤 → 直接顯示結果 ===
  async function bootstrap() {
    const token = getGoogleToken();
    if (!token) {
      hideAllSections();
      authGate.hidden = false;
      renderGoogleSignIn();
      return;
    }
    hideAllSections();
    loadingSection.hidden = false;
    try {
      const r = await fetch(`${WORKER_API}/ziwei-my-chart`, { headers: authHeaders() });
      const data = await r.json();
      if (!data.ok) throw new Error(data.error || '無法讀取命盤');
      if (data.exists) {
        showResult(data);
      } else {
        hideAllSections();
        formSection.hidden = false;
      }
    } catch (err: any) {
      showError(err.message || '無法連線');
    }
  }
  bootstrap();
</script>

